{
  "version": "1.0.0",
  "metadata": {
    "project": "AI List Assist - Consignment & Return Protocol",
    "framework": "GSA PBS External Agency COR Toolkit / EASI",
    "compliance_url": "https://www.gsa.gov/buy-through-us/purchasing-programs/procurement-consolidation/pbs-external-agency-cor-toolkit/file-naming-requirements"
  },
  "database_schema": {
    "participants": {
      "collection_path": "/artifacts/${appId}/public/data/participants",
      "fields": {
        "participant_id": "string (unique)",
        "kyc_status": "enum [PENDING, VERIFIED, REJECTED]",
        "tax_nexus_code": "string (ISO-3166-2)",
        "payout_method_type": "string",
        "last_verification_utc": "timestamp"
      }
    },
    "assets": {
      "collection_path": "/artifacts/${appId}/public/data/assets",
      "fields": {
        "asset_id": "string (unique)",
        "participant_id": "string (foreign_key)",
        "provenance_hash": "string (SHA-256)",
        "basis_value": "number (decimal)",
        "condition_state": "enum [MINT, GOOD, DAMAGED, INAD]",
        "current_status": "enum [RECEIVED, LISTED, SOLD, RETURN_PENDING, CLOSED]"
      }
    },
    "transactions": {
      "collection_path": "/artifacts/${appId}/public/data/transactions",
      "fields": {
        "transaction_id": "uuid",
        "asset_id": "string (foreign_key)",
        "call_type": "enum [LISTING_SUBMISSION, SALE_RECORD, RETURN_CLAIM, DISPUTE_RESOLUTION]",
        "commission_multiplier": "number (0.00-1.00)",
        "timestamp_iso8601": "string",
        "carrier_trace_id": "string (e.g., 9434608106245789775719)"
      }
    },
    "documentation": {
      "collection_path": "/artifacts/${appId}/public/data/documents",
      "fields": {
        "document_id": "string",
        "gsa_file_name": "string (compliant_syntax)",
        "persistent_url": "string (verified_href)",
        "mime_type": "string (application/pdf | image/jpeg)",
        "document_category": "enum [VALUATION, DAMAGE_PROOF, SHIP_LABEL]"
      }
    }
  },
